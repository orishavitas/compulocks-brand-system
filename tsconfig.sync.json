{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "outDir": ".build-sync",
    "rootDir": ".",
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": [
    "adapters/**/*.ts",
    "agents/**/*.ts",
    "librarian/**/*.ts",
    "orchestrator/**/*.ts",
    "qa/**/*.ts"
  ],
  "exclude": [
    "dashboard",
    "node_modules",
    "dist",
    "build"
  ]
}
